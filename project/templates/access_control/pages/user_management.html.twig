{% extends 'access_control/layout.html.twig' %}
{% block title %}User management | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">
    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}
    <div class="ac-main">
        {% include 'access_control/components/_topbar.html.twig' with { title: 'User management', subtitle: 'Manage roles and accounts', username: userName } %}
        <section class="ac-card">
            <div class="ac-row-between">
                <h3>Users</h3>
                <button class="ac-btn" data-action="click->modal#open" data-modal-id-param="create-user-modal">Add user</button>
            </div>
            {% include 'access_control/components/_table.html.twig' with {
                columns: ['Username', 'Email', 'Role', 'Account', 'Presence'],
                rows: users,
                searchable: true
            } %}
        </section>
    </div>
</div>

<div class="ac-modal" id="create-user-modal" data-controller="modal" data-modal-target="container" hidden>
    <div class="ac-modal-content">
        <h3>Create user</h3>
        <form class="ac-form" method="post" action="{{ path('api_auth_signup') }}">
            <label>Email<input class="ac-input" name="email" type="email" required></label>
            <label>Password<input class="ac-input" name="password" type="password" required></label>
            <label>Confirm password<input class="ac-input" name="confirmPassword" type="password" required></label>
            <label>Role
                <select class="ac-input" name="role">
                    <option value="PATIENT">Patient</option>
                    <option value="THERAPIST">Therapist</option>
                    <option value="ADMIN">Admin</option>
                </select>
            </label>
            <div class="ac-row-end">
                <button class="ac-ghost-btn" type="button" data-action="modal#close">Cancel</button>
                <button class="ac-btn" type="submit">Save</button>
            </div>
        </form>
    </div>
</div>
{% endblock %}
