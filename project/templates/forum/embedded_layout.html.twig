{% extends 'access_control/layout.html.twig' %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css?family=Open+Sans:300,400,600,700" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="{{ asset('vendor/argon/css/nucleo-icons.css') }}" rel="stylesheet">
    <link href="{{ asset('vendor/argon/css/nucleo-svg.css') }}" rel="stylesheet">
    <link href="{{ asset('vendor/argon/css/font-awesome.css') }}" rel="stylesheet">
    <link href="{{ asset('vendor/argon/css/argon-design-system.min.css') }}" rel="stylesheet">
    <style>
        .forum-input,
        .forum-textarea,
        .forum-select,
        .forum-file {
            border-radius: 14px;
            border: 1px solid rgba(15, 118, 140, 0.2);
            background: #f6fbfd;
            padding: 0.75rem 0.9rem;
            box-shadow: 0 8px 24px rgba(15, 118, 140, 0.08);
        }
        .forum-textarea {
            min-height: 180px;
        }
        .forum-input:focus,
        .forum-textarea:focus,
        .forum-select:focus,
        .forum-file:focus {
            border-color: rgba(15, 118, 140, 0.55);
            box-shadow: 0 0 0 0.2rem rgba(15, 118, 140, 0.12);
        }
    </style>
{% endblock %}

{% block content %}
<div class="ac-app-layout">
    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}
    <div class="ac-main">
        {% include 'access_control/components/_topbar.html.twig' with {
            title: topbarTitle|default('Forum'),
            subtitle: topbarSubtitle|default('Community discussions'),
            username: userName|default('')
        } %}
        {% if showForumNav|default(false) %}
            {% set currentRoute = app.request.attributes.get('_route')|default('') %}
            {% set forumNav = [
                { label: 'Home', route: 'app_forum_feed' },
                { label: 'My Threads', route: 'app_forum_my_threads' },
                { label: 'Archived', route: 'app_forum_archived' },
                { label: 'Followed', route: 'app_forum_followed' }
            ] %}
            <div class="container stats-shell pt-2">
                <section class="card-soft front-nav-box p-3 d-flex flex-wrap align-items-center justify-content-between gap-2">
                    <div>
                        <p class="mb-1 section-kicker text-uppercase">Frontoffice</p>
                        <h2 class="h6 m-0">Forum Navigation</h2>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                        {% for item in forumNav %}
                            {% set isActive = currentRoute == item.route %}
                            <a class="btn btn-sm {{ isActive ? 'btn-primary front-nav-btn is-active' : 'btn-outline-primary front-nav-btn' }}" href="{{ path(item.route) }}">{{ item.label }}</a>
                        {% endfor %}
                    </div>
                </section>
            </div>
        {% endif %}
        {% block forum_content %}{% endblock %}
    </div>
</div>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="{{ asset('vendor/argon/js/argon-bootstrap5-bridge.js') }}"></script>
{% endblock %}
