<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>Export PDF - Rêves</title>

    <style>
        body {
            font-family: Arial, sans-serif;
            font-size: 12px;
            color: #136163;
            margin: 20px;
        }

        h1 {
            text-align: center;
            margin-bottom: 10px;
            color: #136163;
        }

        .meta {
            text-align: right;
            margin-bottom: 15px;
            font-size: 11px;
            color: #18848e;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 10px;
        }

        th, td {
            border: 1px solid #b3ecf1; /* ✅ corrigé */
            padding: 8px;
            text-align: left;
            vertical-align: top;
            word-break: break-word;
        }

        th {
            background: #b3ecf1;
            color: #136163;
            font-weight: bold;
        }

        tr:nth-child(even) {
            background: #f6fcfd;
        }

        /* ✅ gestion multi-page Gotenberg */
        thead {
            display: table-header-group;
        }

        tfoot {
            display: table-footer-group;
        }

        tr {
            page-break-inside: avoid;
        }

        /* footer */
        .footer {
            position: fixed;
            bottom: 10px;
            left: 0;
            right: 0;
            text-align: center;
            font-size: 10px;
            color: #999;
        }
    </style>
</head>

<body>

<h1>Liste des rêves</h1>

<div class="meta">
    Généré le : {{ generatedAt ? generatedAt|date("d/m/Y H:i") : "now"|date("d/m/Y H:i") }}
</div>

<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Titre</th>
        <th>Type</th>
        <th>Humeur</th>
        <th>Intensité</th>
        <th>Couleur</th>
        <th>Récurrent</th>
    </tr>
    </thead>

    <tbody>
    {% for reve in reves %}
        <tr>
            <td>{{ reve.createdAt ? reve.createdAt|date('d/m/Y') : '—' }}</td>
            <td>{{ reve.titre ?? '—' }}</td>
            <td>{{ reve.typeReve ?? '—' }}</td>
            <td>{{ reve.humeur ?? '—' }}</td>
            <td>{{ reve.intensite ?? '—' }}</td>
            <td>{{ reve.couleur ? 'Oui' : 'Non' }}</td>
            <td>{{ reve.recurrent ? 'Oui' : 'Non' }}</td>
        </tr>
    {% else %}
        <tr>
            <td colspan="7" style="text-align:center;">
                Aucun rêve trouvé.
            </td>
        </tr>
    {% endfor %}
    </tbody>
</table>

<div class="footer">
    Serinity • Analyse des rêves
</div>

</body>
</html>