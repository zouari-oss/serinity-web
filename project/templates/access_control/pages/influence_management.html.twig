{% extends 'access_control/layout.html.twig' %}
{% block title %}Influence management | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">
    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}
    <div class="ac-main">
        {% include 'access_control/components/_topbar.html.twig' with { title: 'Influence management', subtitle: 'Manage available influences', username: userName } %}
        {% for message in app.flashes('success') %}
            <section class="ac-card"><p style="color: var(--success);">{{ message }}</p></section>
        {% endfor %}
        {% for message in app.flashes('error') %}
            <section class="ac-card"><p style="color: var(--danger);">{{ message }}</p></section>
        {% endfor %}

        <section class="ac-card">
            <div class="ac-row-between ac-mood-history-head">
                <h3>Add influence</h3>
                <a class="ac-ghost-btn" href="{{ path('ac_ui_mood') }}">Back to mood analytics</a>
            </div>
            <form method="post" action="{{ path('ac_ui_influence', { page: influences.currentPageNumber|default(1), perPage: perPage|default('10'), direction: direction|default('asc') }) }}" class="ac-form ac-inline-form">
                <input type="hidden" name="_token" value="{{ csrf_token('influence_create') }}">
                <label>
                    <span class="ac-label">Name</span>
                    <input class="ac-input" type="text" name="name" maxlength="60" required placeholder="e.g. Work/Study">
                </label>
                <button class="ac-btn ac-btn-primary" type="submit">Add influence</button>
            </form>
        </section>

        <section class="ac-card">
            <div class="ac-row-between ac-mood-history-head">
                <h3>Influences</h3>
                <form method="get" action="{{ path('ac_ui_influence') }}" class="ac-inline-form ac-list-controls">
                    <input type="hidden" name="page" value="1">
                    <label>
                        <span class="ac-label">Sort</span>
                        <select class="ac-input" name="direction">
                            <option value="asc" {{ direction == 'asc' ? 'selected' : '' }}>ID ↑</option>
                            <option value="desc" {{ direction == 'desc' ? 'selected' : '' }}>ID ↓</option>
                        </select>
                    </label>
                    <label>
                        <span class="ac-label">Per page</span>
                        <select class="ac-input" name="perPage">
                            <option value="5" {{ perPage == '5' ? 'selected' : '' }}>5</option>
                            <option value="10" {{ perPage == '10' ? 'selected' : '' }}>10</option>
                            <option value="20" {{ perPage == '20' ? 'selected' : '' }}>20</option>
                            <option value="all" {{ perPage == 'all' ? 'selected' : '' }}>All</option>
                        </select>
                    </label>
                    <button class="ac-ghost-btn" type="submit">Apply</button>
                </form>
            </div>
            <div class="ac-table-container">
                <table class="ac-table">
                    <thead>
                        <tr>
                            <th>
                                <a class="ac-table-sort-link" href="{{ path('ac_ui_influence', { page: 1, perPage: perPage, direction: direction == 'asc' ? 'desc' : 'asc' }) }}">
                                    ID {{ direction == 'desc' ? '↓' : '↑' }}
                                </a>
                            </th>
                            <th>Name</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for influence in influences %}
                            <tr>
                                <td>{{ influence.id }}</td>
                                <td>
                                    <form method="post" action="{{ path('ac_ui_influence_edit', { id: influence.id, page: influences.currentPageNumber, perPage: perPage, direction: direction }) }}" class="ac-inline-form">
                                        <input type="hidden" name="_token" value="{{ csrf_token('influence_edit_' ~ influence.id) }}">
                                        <input class="ac-input" type="text" name="name" maxlength="60" value="{{ influence.name }}" required>
                                        <button class="ac-ghost-btn" type="submit">Save</button>
                                    </form>
                                </td>
                                <td>
                                    <form method="post" action="{{ path('ac_ui_influence_delete', { id: influence.id, page: influences.currentPageNumber, perPage: perPage, direction: direction }) }}">
                                        <input type="hidden" name="_token" value="{{ csrf_token('influence_delete_' ~ influence.id) }}">
                                        <button class="ac-danger-btn" type="submit">Delete</button>
                                    </form>
                                </td>
                            </tr>
                        {% else %}
                            <tr><td colspan="3">No influences found.</td></tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
            {% if influences.pageCount > 1 %}
                <nav class="ac-pagination" aria-label="Influence pages">
                    {% if influences.currentPageNumber > 1 %}
                        <a class="ac-ghost-btn" href="{{ path('ac_ui_influence', { page: influences.currentPageNumber - 1, perPage: perPage, direction: direction }) }}">Previous</a>
                    {% else %}
                        <span class="ac-ghost-btn is-disabled" aria-disabled="true">Previous</span>
                    {% endif %}

                    <span class="ac-badge ac-badge-secondary">Page {{ influences.currentPageNumber }} / {{ influences.pageCount }}</span>

                    {% if influences.currentPageNumber < influences.pageCount %}
                        <a class="ac-ghost-btn" href="{{ path('ac_ui_influence', { page: influences.currentPageNumber + 1, perPage: perPage, direction: direction }) }}">Next</a>
                    {% else %}
                        <span class="ac-ghost-btn is-disabled" aria-disabled="true">Next</span>
                    {% endif %}
                </nav>
            {% endif %}
        </section>
    </div>
</div>
{% endblock %}
