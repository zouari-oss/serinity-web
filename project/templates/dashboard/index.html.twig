<section class="ac-card" style="margin-bottom:1.5rem;">

    <div class="ac-row-between" style="margin-bottom:1rem;">
        <div>
            <h2 style="margin:0;">Statistics Dashboard</h2>
            <p style="margin:.35rem 0 0;color:var(--text-muted);">
                Performance & appointments analytics
            </p>
        </div>
    </div>

    <div class="stats-grid">

        <div class="chart-box">
            <h3>Appointments by Status</h3>
            <canvas id="statusChart"></canvas>
        </div>

        <div class="chart-box">
            <h3>Appointments by Month</h3>
            <canvas id="monthChart"></canvas>
        </div>

        <div class="chart-box">
            <h3>Appointments by Week Day</h3>
            <canvas id="dayChart"></canvas>
        </div>

        <div class="chart-box">
            <h3>Emergency Levels (AI)</h3>
            <canvas id="emergencyChart"></canvas>
        </div>

    </div>

</section>


<style>
.stats-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(420px,1fr));
    gap:1rem;
}

.chart-box{
    background:var(--surface);
    border:1px solid var(--border-color);
    border-radius:18px;
    padding:1rem;
    box-shadow:0 10px 25px rgba(0,0,0,.05);
}

.chart-box h3{
    margin:0 0 1rem;
    font-size:1rem;
}

.chart-box canvas{
    width:100%!important;
    height:320px!important;
}

@media(max-width:768px){
    .stats-grid{
        grid-template-columns:1fr;
    }
}
</style>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
/* =========================
   STATUS
========================= */
new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
        labels: [
            {% for row in statusStats %}
                '{{ row.status }}',
            {% endfor %}
        ],
        datasets: [{
            data: [
                {% for row in statusStats %}
                    {{ row.total }},
                {% endfor %}
            ],
            backgroundColor: [
                '#16a34a',
                '#f59e0b',
                '#ef4444',
                '#3b82f6'
            ]
        }]
    },
    options:{
        responsive:true,
        maintainAspectRatio:false
    }
});


/* =========================
   MONTH
========================= */
new Chart(document.getElementById('monthChart'), {
    type: 'line',
    data: {
        labels: [
            {% for row in monthStats %}
                '{{ row.month_label }}',
            {% endfor %}
        ],
        datasets: [{
            label:'Appointments',
            data: [
                {% for row in monthStats %}
                    {{ row.total }},
                {% endfor %}
            ],
            borderColor:'#3b82f6',
            backgroundColor:'rgba(59,130,246,.15)',
            fill:true,
            tension:.35
        }]
    },
    options:{
        responsive:true,
        maintainAspectRatio:false
    }
});


/* =========================
   DAY
========================= */
new Chart(document.getElementById('dayChart'), {
    type: 'bar',
    data: {
        labels: [
            {% for row in dayStats %}
                '{{ row.day_name }}',
            {% endfor %}
        ],
        datasets: [{
            label:'Appointments',
            data: [
                {% for row in dayStats %}
                    {{ row.total }},
                {% endfor %}
            ],
            backgroundColor:'#10b981',
            borderRadius:10
        }]
    },
    options:{
        responsive:true,
        maintainAspectRatio:false
    }
});


/* =========================
   EMERGENCY
========================= */
new Chart(document.getElementById('emergencyChart'), {
    type: 'polarArea',
    data: {
        labels: ['Low','Medium','High','Emergency'],
        datasets: [{
            data: [
                {{ emergencyStats.low }},
                {{ emergencyStats.medium }},
                {{ emergencyStats.high }},
                {{ emergencyStats.emergency }}
            ],
            backgroundColor:[
                '#22c55e',
                '#eab308',
                '#f97316',
                '#dc2626'
            ]
        }]
    },
    options:{
        responsive:true,
        maintainAspectRatio:false
    }
});
</script>
