{% extends 'access_control/layout.html.twig' %}
{% block title %}Profile | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">
    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}
    <div class="ac-main">
        {% include 'access_control/components/_topbar.html.twig' with { title: 'Profile', subtitle: 'Update account information', username: userName } %}
        <section class="ac-card">
            <form class="ac-form ac-grid-two" method="post">
                <label>Username<input class="ac-input" type="text" value="{{ profile.username }}"></label>
                <label>Email<input class="ac-input" type="email" value="{{ profile.email }}"></label>
                <label>First name<input class="ac-input" type="text" value="{{ profile.firstName }}"></label>
                <label>Last name<input class="ac-input" type="text" value="{{ profile.lastName }}"></label>
                <label>Country<input class="ac-input" type="text" value="{{ profile.country }}"></label>
                <label>State<input class="ac-input" type="text" value="{{ profile.state }}"></label>
                <label class="ac-col-span-2">About
                    <textarea class="ac-input" rows="4">{{ profile.aboutMe }}</textarea>
                </label>
                <div class="ac-row-end ac-col-span-2"><button class="ac-btn" type="button">Save changes</button></div>
            </form>
        </section>
    </div>
</div>
{% endblock %}
