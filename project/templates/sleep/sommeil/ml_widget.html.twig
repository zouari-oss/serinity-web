{# templates/sleep/sommeil/ml_widget.html.twig #}

<div class="ac-card">

  <div class="ac-row-between" style="margin-bottom: 1rem; gap: 1rem; flex-wrap: wrap;">
    <div>
      <h3 style="margin:0;">Prédiction de votre nuit</h3>
      <p style="margin:0.25rem 0 0;font-size:0.85rem;color:var(--color-text-muted);">
        Estimation de la qualité de sommeil et de l'heure de réveil optimale, basée sur vos habitudes.
      </p>
    </div>
    <span class="ac-ghost-btn" style="pointer-events:none;">Machine Learning</span>
  </div>

  <form
          id="sleepMLForm"
          method="post"
          action="javascript:void(0);"
          novalidate
          data-turbo="false"
          class="ac-form">

    <div class="form-section-label">🌙 Informations de coucher</div>
    <div class="form-grid">
      <div class="form-group">
        <label class="ac-label" for="bedtime_hour">Heure de coucher</label>
        <input type="number" class="ac-input" id="bedtime_hour" name="bedtime_hour"
               min="0" max="23" value="23" required>
      </div>

      <div class="form-group">
        <label class="ac-label" for="sleep_duration">Durée de sommeil (h)</label>
        <input type="number" class="ac-input" id="sleep_duration" name="sleep_duration"
               min="1" max="12" step="0.5" value="7.5" required>
      </div>

      <div class="form-group">
        <label class="ac-label" for="mood_bedtime">Humeur au coucher</label>
        <select class="ac-input" id="mood_bedtime" name="mood_bedtime" required>
          <option value="calm">😌 Calme</option>
          <option value="neutral" selected>😐 Neutre</option>
          <option value="stressed">😰 Stressé(e)</option>
          <option value="tired">😴 Fatigué(e)</option>
        </select>
      </div>
    </div>

    <div class="form-section-label">🌡️ Environnement</div>
    <div class="form-grid">
      <div class="form-group">
        <label class="ac-label" for="temperature">Température chambre (°C)</label>
        <input type="number" class="ac-input" id="temperature" name="temperature"
               min="10" max="35" step="0.5" value="19" required>
      </div>

      <div class="form-group">
        <label class="ac-label" for="noise_level">Niveau sonore</label>
        <select class="ac-input" id="noise_level" name="noise_level" required>
          <option value="quiet" selected>🔇 Calme</option>
          <option value="moderate">🔉 Modéré</option>
          <option value="noisy">🔊 Bruyant</option>
        </select>
      </div>
    </div>

    <div class="form-section-label">👤 Profil personnel</div>
    <div class="form-grid">
      <div class="form-group">
        <label class="ac-label" for="age">Âge</label>
        <input type="number" class="ac-input" id="age" name="age" min="1" max="120" value="25" required>
      </div>

      <div class="form-group">
        <label class="ac-label" for="bmi_category">Catégorie IMC</label>
        <select class="ac-input" id="bmi_category" name="bmi_category" required>
          <option value="Underweight">Insuffisance pondérale</option>
          <option value="Normal" selected>Normal</option>
          <option value="Overweight">Surpoids</option>
          <option value="Obese">Obèse</option>
        </select>
      </div>

      <div class="form-group">
        <label class="ac-label" for="physical_activity_minutes">Activité physique (min/jour)</label>
        <input type="number" class="ac-input" id="physical_activity_minutes" name="physical_activity_minutes"
               min="0" max="180" value="30" required>
      </div>

      <div class="form-group" style="grid-column: 1 / -1;">
        <label class="ac-label" for="stress_level">
          Niveau de stress : <span id="stressDisplay">5</span>/10
        </label>
        <div class="slider-wrap" style="display:flex;align-items:center;gap:0.75rem;">
          <input type="range" id="stress_level" name="stress_level"
                 min="1" max="10" value="5" style="flex:1;">
          <span class="slider-val" id="stressVal" style="min-width:1.5rem;text-align:center;">5</span>
        </div>
      </div>
    </div>

    <button type="submit" class="ac-btn ac-btn-primary" id="analyseBtn"
            style="margin-top: 1rem; width: 100%;">
      <span id="btnText">🔍 Analyser mon sommeil</span>
    </button>
  </form>

  <div id="mlError" class="rv-modal-error" style="display:none; margin-top: 1rem;"></div>

  <div id="mlResults" style="display:none; margin-top: 1.25rem; display:flex; flex-direction:column; gap:1rem;">

    <div class="ac-row" style="gap:1rem; flex-wrap:wrap;">
      <div class="ac-card" style="flex:1; min-width:220px; padding:1rem;">
        <div class="ac-label" style="margin-bottom:0.5rem;">Qualité de sommeil</div>
        <div style="display:flex;align-items:center;gap:0.75rem;">
          <span id="resQualityIcon" style="font-size:2rem;">😐</span>
          <div>
            <div id="resQualityLabel" style="font-weight:600;">—</div>
            <div id="resQualityNum" style="font-size:0.85rem;color:var(--color-text-muted);">
              Score : —/10
            </div>
          </div>
        </div>
        <div style="margin-top:0.75rem;height:6px;border-radius:999px;background:#e5e7eb;overflow:hidden;">
          <div id="resQualityBar"
               style="height:100%;width:0%;background:var(--color-primary);border-radius:999px;transition:width .4s ease;">
          </div>
        </div>
      </div>

      <div class="ac-card" style="flex:1; min-width:220px; padding:1rem;">
        <div class="ac-label" style="margin-bottom:0.5rem;">Heure de réveil optimal</div>
        <div id="resWakeTime" style="font-size:1.5rem;font-weight:700;">—h—</div>
        <div id="resCycles" style="font-size:0.85rem;color:var(--color-text-muted);">
          — cycles de sommeil
        </div>
      </div>
    </div>

    <div class="ac-card" style="padding:1rem;">
      <div id="resAdvice"></div>
    </div>

    <div class="ac-card" style="padding:1rem;">
      <h4 style="margin-top:0;">💡 Recommandations personnalisées</h4>
      <ul id="resTips" style="margin:0.75rem 0 0; padding-left:1rem;"></ul>
    </div>
  </div>
</div>