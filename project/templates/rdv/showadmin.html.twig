{% extends 'access_control/layout.html.twig' %}

{% block title %}Consultation Live Admin | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">

{% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}

<div class="ac-main" data-controller="flash-toast">

{% include 'access_control/components/_topbar.html.twig' with {
    title: 'Gestion Consultation',
    subtitle: 'Patient dossier + vidéo meeting sécurisé',
    username: userName
} %}

<section class="rdv-wrapper">

<style>
.rdv-wrapper{
    max-width:1450px;
    margin:auto;
    padding:1.2rem;
}

.hero{
    background:linear-gradient(135deg,#0f172a,#1e293b,#2F6F6D);
    color:#fff;
    border-radius:24px;
    padding:1.4rem;
    margin-bottom:1rem;
    box-shadow:0 25px 45px rgba(0,0,0,.18);
}

.hero-top{
    display:flex;
    justify-content:space-between;
    gap:1rem;
    flex-wrap:wrap;
    align-items:center;
}

.patient-box{
    display:flex;
    gap:1rem;
    align-items:center;
}

.avatar{
    width:72px;
    height:72px;
    border-radius:50%;
    background:rgba(255,255,255,.14);
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.35rem;
    font-weight:800;
}

.name{
    margin:0;
    font-size:1.15rem;
    font-weight:800;
}

.sub{
    margin-top:.3rem;
    opacity:.85;
}

.live{
    background:#16a34a;
    color:#fff;
    padding:.7rem 1rem;
    border-radius:999px;
    font-weight:800;
}

.wait{
    background:#f59e0b;
    color:#fff;
    padding:.7rem 1rem;
    border-radius:999px;
    font-weight:800;
}

.grid{
    display:grid;
    grid-template-columns:390px 1fr;
    gap:1rem;
}

.side{
    background:#fff;
    border:1px solid #e2e8f0;
    border-radius:22px;
    padding:1rem;
}

.info{
    background:#f8fafc;
    border:1px solid #eef2f7;
    border-radius:18px;
    padding:1rem;
    margin-bottom:.8rem;
}

.label{
    font-size:.74rem;
    text-transform:uppercase;
    color:#94a3b8;
    font-weight:800;
    margin-bottom:.35rem;
}

.value{
    font-weight:700;
    color:#0f172a;
    line-height:1.5;
}

.actions{
    display:flex;
    gap:.7rem;
    flex-wrap:wrap;
    margin-top:1rem;
}

.btn{
    text-decoration:none;
    padding:.9rem 1rem;
    border-radius:14px;
    font-weight:800;
    border:none;
}

.btn-green{
    background:#16a34a;
    color:#fff;
}

.btn-red{
    background:#dc2626;
    color:#fff;
}

.btn-back{
    background:#0f172a;
    color:#fff;
}

.meet{
    background:#fff;
    border:1px solid #e2e8f0;
    border-radius:22px;
    padding:1rem;
    min-height:760px;
}

.jitsi{
    height:720px;
    overflow:hidden;
    border-radius:18px;
    border:1px solid #e2e8f0;
}

.empty{
    height:720px;
    border-radius:18px;
    background:#f8fafc;
    display:flex;
    align-items:center;
    justify-content:center;
    flex-direction:column;
    text-align:center;
}

@media(max-width:1100px){
    .grid{
        grid-template-columns:1fr;
    }

    .jitsi,.empty{
        height:620px;
    }
}
</style>

{% set patientName = rdv.patient.fullName is defined and rdv.patient.fullName ? rdv.patient.fullName : rdv.patient.email %}

<div class="hero">

<div class="hero-top">

<div class="patient-box">

<div class="avatar">
{{ patientName|slice(0,1)|upper }}
</div>

<div>
<h2 class="name">{{ patientName }}</h2>
<div class="sub">Consultation vidéo thérapeute</div>
</div>

</div>

{% if canJoinMeet %}
<div class="live">● Meeting Ouvert</div>
{% else %}
<div class="wait">Disponible dans {{ minutesLeft }} min</div>
{% endif %}

</div>
</div>


<div class="grid">

<div class="side">

<div class="info">
<div class="label">Date demandée</div>
<div class="value">{{ rdv.dateTime|date('d/m/Y H:i') }}</div>
</div>

{% if rdv.proposedDateTime %}
<div class="info">
<div class="label">Date proposée</div>
<div class="value">{{ rdv.proposedDateTime|date('d/m/Y H:i') }}</div>
</div>
{% endif %}

<div class="info">
<div class="label">Statut</div>
<div class="value">{{ rdv.status }}</div>
</div>

<div class="info">
<div class="label">Motif</div>
<div class="value">{{ rdv.motif ?: 'Consultation générale' }}</div>
</div>

<div class="info">
<div class="label">Description</div>
<div class="value">{{ rdv.description ?: 'Aucune description.' }}</div>
</div>

{% if rdv.doctorNote %}
<div class="info">
<div class="label">Note thérapeute</div>
<div class="value">{{ rdv.doctorNote }}</div>
</div>
{% endif %}

<div class="actions">

{% if rdv.status == 'EN_ATTENTE' %}
<a href="{{ path('app_rdv_accept',{id:rdv.id}) }}" class="btn btn-green">
Accepter
</a>

<a href="{{ path('app_rdv_refuse',{id:rdv.id}) }}" class="btn btn-red">
Refuser
</a>
{% endif %}

<a href="{{ path('app_therapist_rdv') }}" class="btn btn-back">
Retour
</a>

</div>

</div>


<div class="meet">

{% if canJoinMeet %}

<div id="jitsi-container" class="jitsi"></div>

{% else %}

<div class="empty">
<i class="bi bi-camera-video-off" style="font-size:3rem;color:#94a3b8;"></i>
<h3>Meeting fermé</h3>
<p>Le salon vidéo ouvre 1 heure avant le rendez-vous.</p>
</div>

{% endif %}

</div>

</div>

</section>

{% if canJoinMeet %}
<script src="https://meet.jit.si/external_api.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function(){

    const api = new JitsiMeetExternalAPI("meet.jit.si", {
        roomName: "{{ roomName }}",
        parentNode: document.querySelector('#jitsi-container'),
        width: "100%",
        height: "100%",

        userInfo:{
            displayName:"Dr {{ userName|e('js') }}"
        },

        configOverwrite:{
            prejoinPageEnabled:false,
            startWithAudioMuted:false,
            startWithVideoMuted:false
        },

        interfaceConfigOverwrite:{
            SHOW_JITSI_WATERMARK:false,
            SHOW_BRAND_WATERMARK:false
        }
    });

});
</script>
{% endif %}

</div>
</div>
{% endblock %}