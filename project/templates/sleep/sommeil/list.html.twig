{% extends 'sleep/_layout.html.twig' %}
{% block title %}Mes nuits — Serinity Sleep{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('assets/css/sleep-weather-widget.css') }}">
    <style>
        .powerbi-wrapper {
            position: relative;
            width: 100%;
            aspect-ratio: 1140 / 541.25;
            border-radius: var(--radius-lg, 0.75rem);
            overflow: hidden;
            box-shadow: var(--shadow-md);
            margin-bottom: var(--space-8, 2rem);
            background: var(--color-surface);
        }
        .powerbi-wrapper iframe {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            border: none;
        }
    </style>
{% endblock %}

{% block sleep_content %}

    {# ── En-tête ── #}
    <section class="ac-card" style="margin-bottom: 1.5rem;">
        <div class="ac-row-between">
            <div>
                <h2>🌙 Mes nuits de sommeil</h2>
                <p style="color: var(--color-text-muted); margin-top: 0.25rem;">
                    Consultez vos nuits, comparez vos durées et gardez une vue claire sur votre récupération.
                </p>
            </div>
            <div style="display: flex; gap: 0.75rem; flex-wrap: wrap; align-items: center;">
                <a href="{{ path('app_sommeil_index') }}" class="ac-ghost-btn">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    Retour
                </a>
                <button type="button" class="ac-ghost-btn" id="openSleepWeatherBtn">
                    <span class="material-symbols-outlined" style="font-size:18px;">cloud</span>
                    Météo sommeil
                </button>

                <button type="button" class="ac-ghost-btn" id="openSleepMLBtn">
                    <span class="material-symbols-outlined" style="font-size:18px;">auto_awesome</span>
                    Prédiction sommeil
                </button>

                <button type="button" class="ac-btn ac-btn-primary"
                        onclick="openSommeilModal('{{ path('app_sommeil_new') }}')">
                    <span class="material-symbols-outlined" style="font-size:18px;">add</span>
                    Ajouter une nuit
                </button>
            </div>
        </div>
    </section>

    {# ── Power BI ── #}
    <section class="ac-card" style="margin-bottom: 1.5rem;">
        <div style="margin-bottom: 1rem;">
            <h3>Résumé de vos nuits</h3>
            <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-top: 0.25rem;">
                Une lecture rapide de votre rythme, de la qualité moyenne et de votre état au réveil.
            </p>
        </div>
        <div class="powerbi-wrapper">
            <iframe title="sommeil"
                    src="https://app.powerbi.com/reportEmbed?reportId=0e045a52-f58f-44af-ae60-1134d355b44f&autoAuth=true&ctid=604f1a96-cbe8-43f8-abbf-f8eaf5d85730"
                    frameborder="0" allowFullScreen="true" loading="lazy"></iframe>
        </div>
    </section>

    <div class="rv-modal-overlay" id="sleepMlModal" hidden>
        <div class="rv-modal-dialog" role="dialog" aria-modal="true" aria-label="Fenêtre de prédiction sommeil">
            <button type="button" class="rv-modal-close" onclick="closeSleepMlModal()" aria-label="Fermer">×</button>
            <div class="rv-modal-content" id="sleepMlContent">
                <div class="rv-modal-loading">Chargement...</div>
            </div>
        </div>
    </div>

    {# ── Filtres ── #}
    <section class="ac-card" style="margin-bottom: 1.5rem;">
        <form method="get" class="ac-form" style="display: flex; flex-wrap: wrap; gap: 0.75rem; align-items: flex-end;">

            <label style="flex: 1; min-width: 160px;">
                <span class="ac-label">Recherche</span>
                <input type="text" name="q" value="{{ filters.q|default('') }}"
                       placeholder="Recherche dynamique..." class="ac-input">
            </label>

            <label style="flex: 1; min-width: 160px;">
                <span class="ac-label">Qualité</span>
                <select name="qualite" class="ac-input">
                    <option value="">Toutes les qualités</option>
                    <option value="Excellente" {{ filters.qualite|default('') == 'Excellente' ? 'selected' }}>Excellente</option>
                    <option value="Bonne"      {{ filters.qualite|default('') == 'Bonne'      ? 'selected' }}>Bonne</option>
                    <option value="Moyenne"    {{ filters.qualite|default('') == 'Moyenne'    ? 'selected' }}>Moyenne</option>
                    <option value="Mauvaise"   {{ filters.qualite|default('') == 'Mauvaise'   ? 'selected' }}>Mauvaise</option>
                </select>
            </label>

            <label style="flex: 1; min-width: 160px;">
                <span class="ac-label">Humeur réveil</span>
                <input type="text" name="humeur" value="{{ filters.humeur|default('') }}"
                       placeholder="Humeur réveil" class="ac-input">
            </label>

            <label style="flex: 1; min-width: 160px;">
                <span class="ac-label">Durée</span>
                <select name="insuffisant" class="ac-input">
                    <option value="">Tous</option>
                    <option value="1" {{ filters.insuffisant|default('') == '1' ? 'selected' }}>Sommeil insuffisant</option>
                </select>
            </label>

            <input type="hidden" name="sort"      value="{{ filters.sort|default('s.dateNuit') }}">
            <input type="hidden" name="direction" value="{{ filters.direction|default('DESC') }}">

            <div style="display: flex; gap: 0.5rem; flex-wrap: wrap; padding-top: 1.4rem;">
                <button type="submit" class="ac-btn ac-btn-primary">
                    <span class="material-symbols-outlined" style="font-size:16px;">filter_list</span>
                    Filtrer
                </button>
                <a href="{{ path('app_sommeil_list') }}" class="ac-ghost-btn">Réinitialiser</a>
                <a href="{{ path('app_sommeil_export_csv', app.request.query.all) }}" class="ac-ghost-btn">
                    <span class="material-symbols-outlined" style="font-size:16px;">table_view</span>
                    Excel
                </a>
                <a href="{{ path('app_sommeil_export_pdf', app.request.query.all) }}" target="_blank" class="ac-ghost-btn">
                    <span class="material-symbols-outlined" style="font-size:16px;">picture_as_pdf</span>
                    PDF
                </a>
            </div>
        </form>
    </section>

    {# ── Tableau ── #}
    <section class="ac-card">
        {% include 'sleep/sommeil/components/_table.html.twig' with {
            sommeils: sommeils,
            filters: filters
        } %}
    </section>

    {# ── Modales & widgets ── #}
    {% include 'sleep/sommeil/components/_delete_modal.html.twig' %}
    {% include 'sleep/sommeil/components/_weather_widget.html.twig' %}

    <div class="rv-modal-overlay" id="sommeilModal" hidden>
        <div class="rv-modal-dialog" role="dialog" aria-modal="true" aria-label="Fenêtre de détail de la nuit">
            <button type="button" class="rv-modal-close" onclick="closeSommeilModal()" aria-label="Fermer">×</button>
            <div class="rv-modal-content" id="sommeilModalContent">
                <div class="rv-modal-loading">Chargement...</div>
            </div>
        </div>
    </div>

{% endblock %}

{% block sleep_javascripts %}
    {{ parent() }}
    <script>
        window.sleepWeatherApiUrl = "{{ path('app_sleep_weather_widget') }}";

        function openDeleteModal(url, label, token) {
            document.getElementById('deleteForm').action = url;
            document.getElementById('deleteForm').querySelector('[name="_token"]').value = token;
            document.getElementById('deleteModalBody').textContent =
                'Supprimer la nuit du "' + label + '" ? Action irréversible.';
            document.getElementById('deleteModal').hidden = false;
        }
        function closeDeleteModal() {
            document.getElementById('deleteModal').hidden = true;
        }

        function openSommeilModal(url) {
            const modal   = document.getElementById('sommeilModal');
            const content = document.getElementById('sommeilModalContent');
            if (!modal || !content) return false;
            modal.hidden = false;
            modal.classList.add('open');
            content.innerHTML = '<div class="rv-modal-loading">Chargement...</div>';
            fetch(url, { headers: { 'X-Requested-With': 'XMLHttpRequest' } })
                .then(r => r.text())
                .then(html => { content.innerHTML = html; bindSommeilModalForms(); })
                .catch(() => {
                    content.innerHTML =
                        '<div class="rv-modal-error">Impossible de charger le contenu.</div>';
                });
            return false;
        }
        function closeSommeilModal() {
            const modal   = document.getElementById('sommeilModal');
            const content = document.getElementById('sommeilModalContent');
            if (!modal || !content) return;
            modal.classList.remove('open');
            modal.hidden = true;
            content.innerHTML = '<div class="rv-modal-loading">Chargement...</div>';
        }
        function bindSommeilModalForms() {
            const modal   = document.getElementById('sommeilModal');
            const content = document.getElementById('sommeilModalContent');
            if (!modal || !content) return;
            content.querySelectorAll('form').forEach(form => {
                form.addEventListener('submit', function(e) {
                    e.preventDefault();
                    fetch(form.action, {
                        method: form.method || 'POST',
                        body: new FormData(form),
                        headers: { 'X-Requested-With': 'XMLHttpRequest' }
                    }).then(async response => {
                        const ct = response.headers.get('content-type') || '';
                        if (ct.includes('application/json')) {
                            const data = await response.json();
                            if (data.success) {
                                closeSommeilModal();
                                window.location.reload();
                                return;
                            }
                        }
                        content.innerHTML = await response.text();
                        bindSommeilModalForms();
                    }).catch(() => {
                        content.innerHTML =
                            '<div class="rv-modal-error">Erreur lors de la soumission.</div>';
                    });
                });
            });
        }

        // IIFE 1 : gestion modales delete + sommeil
        (function() {
            const dm = document.getElementById('deleteModal');
            const sm = document.getElementById('sommeilModal');
            if (dm) dm.addEventListener('click', e => {
                if (e.target === e.currentTarget) closeDeleteModal();
            });
            if (sm) sm.addEventListener('click', e => {
                if (e.target === e.currentTarget) closeSommeilModal();
            });
            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') {
                    closeDeleteModal();
                    closeSommeilModal();
                }
            });
        })();  // ← il manquait ça dans ton code

        // IIFE 2 : bouton Prédiction sommeil ML
        function openSleepMlModal() {
            const modal = document.getElementById('sleepMlModal');
            const content = document.getElementById('sleepMlContent');
            if (!modal || !content) return false;

            modal.hidden = false;
            modal.classList.add('open');
            content.innerHTML = '<div class="rv-modal-loading">Chargement...</div>';

            fetch('{{ path("ml_widget") }}', {
                headers: { 'X-Requested-With': 'XMLHttpRequest' }
            })
                .then(r => r.text())
                .then(html => {
                    content.innerHTML = html;
                    if (window.initSleepMLWidget) {
                        window.initSleepMLWidget();
                    }
                })
                .catch(() => {
                    content.innerHTML =
                        '<div class="rv-modal-error">Erreur lors du chargement du module ML.</div>';
                });

            return false;
        }

        function closeSleepMlModal() {
            const modal = document.getElementById('sleepMlModal');
            const content = document.getElementById('sleepMlContent');
            if (!modal || !content) return;
            modal.classList.remove('open');
            modal.hidden = true;
            content.innerHTML = '<div class="rv-modal-loading">Chargement...</div>';
        }

        (function () {
            const btn = document.getElementById('openSleepMLBtn');
            const modal = document.getElementById('sleepMlModal');

            if (btn) {
                btn.addEventListener('click', function () {
                    openSleepMlModal();
                });
            }

            if (modal) {
                modal.addEventListener('click', e => {
                    if (e.target === e.currentTarget) closeSleepMlModal();
                });
            }

            document.addEventListener('keydown', e => {
                if (e.key === 'Escape') closeSleepMlModal();
            });
        })();
    </script>
    {% include 'sleep/sommeil/ml_widget_js.html.twig' %}

    <script src="{{ asset('assets/js/sleep-weather-widget.js') }}"></script>
{% endblock %}