{% extends 'forum/embedded_layout.html.twig' %}
{% set topbarTitle = 'Suggested thread' %}
{% set topbarSubtitle = 'Personalized suggestion' %}

{% block title %}Suggested Thread{% endblock %}

{% block forum_content %}
<main class="page-shell">
    <div class="container stats-shell">
        <section class="hero-shell hero-shell-forum mb-4 p-4 p-md-5">
            <div class="d-flex flex-wrap justify-content-between align-items-start gap-3">
                <div>
                    <p class="text-uppercase fw-bold mb-1 small text-primary section-kicker">Personalized Suggestion</p>
                    <h1 class="display-6 fw-bold mb-2">Suggested Thread</h1>
                    {% if hasCategorySignals %}
                        <p class="m-0 text-muted">Based on your interactions, we scored {{ signalCategoryCount }} categories and picked one thread you have not interacted with yet.</p>
                    {% else %}
                        <p class="m-0 text-muted">No strong interaction signals yet, so this is a popular thread you have not interacted with yet.</p>
                    {% endif %}
                </div>
                <div class="d-flex flex-wrap gap-2">
                    <a class="btn btn-outline-primary" href="{{ path('app_forum_feed') }}">Back to Feed</a>
                    <a class="btn btn-primary" href="{{ path('app_forum_suggested_thread') }}">Suggest Another</a>
                </div>
            </div>
        </section>

        {% if suggestedThread %}
            <article class="card-soft thread-card p-3 p-md-4">
                <div class="d-flex justify-content-between align-items-start mb-2 gap-2">
                    <div>
                        <h2 class="h4 mb-1">{{ suggestedThread.title }}</h2>
                        <p class="text-muted mb-2 small">By {{ suggestedThread.authorUsername ?: 'Unknown User' }} in {{ suggestedThread.category.name }} • {{ suggestedThread.createdAt|date('Y-m-d H:i') }}</p>
                    </div>
                    <span class="meta-pill {{ suggestedThread.status.value == 'open' ? 'meta-open' : (suggestedThread.status.value == 'locked' ? 'meta-locked' : 'meta-archived') }}">{{ suggestedThread.status.value|upper }}</span>
                </div>

                <p class="mb-3">{{ suggestedThread.content|slice(0, 320) }}{% if suggestedThread.content|length > 320 %}...{% endif %}</p>

                <div class="thread-meta-grid d-flex flex-wrap gap-2 small text-muted mb-3">
                    <span class="thread-meta-item">Type: {{ suggestedThread.type.value }}</span>
                    <span class="thread-meta-item">Likes: {{ suggestedThread.likeCount }}</span>
                    <span class="thread-meta-item">Dislikes: {{ suggestedThread.dislikeCount }}</span>
                    <span class="thread-meta-item">Replies: {{ suggestedThread.replyCount }}</span>
                    <span class="thread-meta-item">Followers: {{ suggestedThread.followCount }}</span>
                </div>

                <a class="btn btn-primary" href="{{ path('app_forum_thread_detail', {id: suggestedThread.id}) }}">Open Suggested Thread</a>
            </article>
        {% else %}
            <section class="card-soft p-4 p-md-5">
                <h2 class="h4 mb-2">No suggestion available right now</h2>
                <p class="text-muted mb-3">You may have already interacted with most available threads. Try again later or create a new thread.</p>
                <a class="btn btn-primary" href="{{ path('app_thread_new') }}">Create New Thread</a>
            </section>
        {% endif %}
    </div>
</main>
{% endblock %}
