{% extends 'forum/embedded_layout.html.twig' %}

{% block title %}{{ mode == 'create' ? 'New Category' : 'Edit Category' }}{% endblock %}

{% block forum_content %}
<main class="page-shell">
    <div class="container" style="max-width: 760px;">
        <section class="card-soft p-4">
            <h1 class="h4 mb-3">{{ mode == 'create' ? 'Add Category' : 'Edit Category' }}</h1>
            {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
            {{ form_row(form.name) }}
            {{ form_row(form.slug) }}
            {{ form_row(form.description) }}
            {{ form_row(form.parent) }}
            <button class="btn btn-primary">Save</button>
            {{ form_end(form) }}
        </section>
    </div>
</main>
{% endblock %}
