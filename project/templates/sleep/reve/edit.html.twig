{% extends 'sleep/_layout.html.twig' %}
{% block title %}Modifier — {{ reve.titre }} — Serinity Sleep{% endblock %}

{% block sleep_content %}

    <section class="ac-card" style="margin-bottom: 1.5rem;">
        <div class="ac-row-between">
            <div>
                <h2>✏️ Modifier le rêve</h2>
                <p style="color: var(--color-text-muted); margin-top: 0.25rem;">
                    {{ reve.titre }}
                </p>
            </div>
            <div style="display: flex; gap: 0.75rem; align-items: center;">
                <a href="{{ path('app_reve_show', {id: reve.id}) }}" class="ac-ghost-btn">
                    <span class="material-symbols-outlined" style="font-size:18px;">arrow_back</span>
                    Retour
                </a>
                <a href="{{ path('app_reve_index') }}" class="ac-ghost-btn">
                    <span class="material-symbols-outlined" style="font-size:18px;">list</span>
                    Tous les rêves
                </a>
            </div>
        </div>
    </section>

    {% include 'sleep/reve/components/_form_modal.html.twig' with {
        form: form,
        reve: reve,
        modal_mode: false
    } %}

{% endblock %}
