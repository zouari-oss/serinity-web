{% extends 'access_control/layout.html.twig' %}
{% block title %}Settings | Serinity{% endblock %}

{% set settingsSaveRoute = settingsSaveRoute|default('user_ui_settings') %}
{% set settingsChangePasswordRoute = settingsChangePasswordRoute|default('user_ui_settings_change_password') %}
{% set settingsDeleteAccountRoute = settingsDeleteAccountRoute|default('user_ui_settings_delete_account') %}

{% block content %}
<div class="ac-app-layout">
    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}
    <div class="ac-main">
        {% include 'access_control/components/_topbar.html.twig' with { title: 'Settings', subtitle: 'Personal preferences', username: userName } %}
        <div data-controller="flash-toast">
            {% for message in app.flashes('success') %}
                <span data-flash-toast-target="message" data-type="success" hidden>{{ message }}</span>
            {% endfor %}
            {% for message in app.flashes('error') %}
                <span data-flash-toast-target="message" data-type="error" hidden>{{ message }}</span>
            {% endfor %}
        </div>
        <section class="ac-card">
            <form class="ac-form" method="post" action="{{ path(settingsSaveRoute) }}">
                <label>
                    <span class="ac-label">Theme</span>
                    <select class="ac-input" name="theme">
                        <option value="system" {{ settings.theme == 'system' ? 'selected' : '' }}>System</option>
                        <option value="light" {{ settings.theme == 'light' ? 'selected' : '' }}>Light</option>
                        <option value="dark" {{ settings.theme == 'dark' ? 'selected' : '' }}>Dark</option>
                    </select>
                </label>
                <label class="ac-check"><input type="checkbox" name="notifications" value="1" {{ settings.notifications ? 'checked' : '' }}> Enable notifications</label>
                <label class="ac-check"><input type="checkbox" name="compactView" value="1" {{ settings.compactView ? 'checked' : '' }}> Compact module view</label>
                <div class="ac-row-end"><button class="ac-btn" type="submit">Save settings</button></div>
            </form>
        </section>
        <section class="ac-card" data-controller="face-settings" data-face-settings-enabled-value="{{ faceRecognitionEnabled ? 'true' : 'false' }}">
            <h3>Face authentication</h3>
            <div class="ac-row-between">
                <span class="ac-label">Status</span>
                <span class="ac-badge" data-face-settings-target="state"></span>
            </div>
            <div class="ac-row-end" style="gap: .5rem;">
                <button class="ac-ghost-btn" type="button" data-action="face-settings#enable">Enable</button>
                <button class="ac-btn" type="button" data-action="face-settings#disable">Disable</button>
            </div>
            <div class="ac-face-auth-block">
                <video class="ac-face-video" data-face-settings-target="video" autoplay playsinline hidden></video>
                <p data-face-settings-target="status" hidden></p>
            </div>
        </section>
        <section class="ac-card" data-controller="two-factor-settings" data-two-factor-settings-enabled-value="{{ twoFactorEnabled ? 'true' : 'false' }}">
            <h3>Two-factor authentication (TOTP)</h3>
            <div class="ac-row-between">
                <span class="ac-label">Status</span>
                <span class="ac-badge" data-two-factor-settings-target="state"></span>
            </div>
            <div class="ac-row-end" style="gap: .5rem;">
                <button class="ac-ghost-btn" type="button" data-action="two-factor-settings#enable">Enable</button>
                <button class="ac-ghost-btn" type="button" data-action="two-factor-settings#verify">Verify setup</button>
                <button class="ac-btn" type="button" data-action="two-factor-settings#disable">Disable</button>
            </div>
            <div data-two-factor-settings-target="setup" hidden>
                <div class="ac-row-center" style="justify-content: center; margin-bottom: .75rem;">
                    <img alt="Authenticator QR code" data-two-factor-settings-target="qrImage" style="max-width: 260px; width: 100%; height: auto; border-radius: .5rem; border: 1px solid rgba(15, 23, 42, .12);" hidden>
                </div>
                <label>
                    <span class="ac-label">Authenticator setup URI (manual fallback)</span>
                    <textarea class="ac-input" rows="2" readonly data-two-factor-settings-target="qrContent"></textarea>
                </label>
                <label>
                    <span class="ac-label">Authentication code</span>
                    <input class="ac-input" type="text" inputmode="numeric" autocomplete="one-time-code" data-two-factor-settings-target="code">
                </label>
            </div>
            <p data-two-factor-settings-target="status" hidden></p>
        </section>
        <section class="ac-card">
            <h3>Security</h3>
            <p style="color: var(--muted);">Change your password securely.</p>
            <form class="ac-form" method="post" action="{{ path(settingsChangePasswordRoute) }}">
                <label>
                    <span class="ac-label">Current password</span>
                    <input class="ac-input" type="password" name="currentPassword" required autocomplete="current-password">
                </label>
                <label>
                    <span class="ac-label">New password</span>
                    <input class="ac-input" type="password" name="newPassword" required minlength="8" autocomplete="new-password">
                </label>
                <label>
                    <span class="ac-label">Confirm new password</span>
                    <input class="ac-input" type="password" name="confirmPassword" required minlength="8" autocomplete="new-password">
                </label>
                <div class="ac-row-end">
                    <button class="ac-btn" type="submit">Change password</button>
                </div>
            </form>
        </section>
        <section class="ac-card">
            <h3>Delete account</h3>
            <p style="color: var(--muted);">Delete your account permanently. This action cannot be undone.</p>
            <form class="ac-form" method="post" action="{{ path(settingsDeleteAccountRoute) }}">
                <label>
                    <span class="ac-label">Current password</span>
                    <input class="ac-input" type="password" name="currentPassword" required autocomplete="current-password">
                </label>
                <label>
                    <span class="ac-label">Type DELETE to confirm</span>
                    <input class="ac-input" type="text" name="confirmDelete" required placeholder="DELETE">
                </label>
                <div class="ac-row-end">
                    <button class="ac-btn" style="background: var(--danger); color: #fff;" type="submit">Delete account</button>
                </div>
            </form>
        </section>
    </div>
</div>
{% endblock %}
