{% extends 'access_control/layout.html.twig' %}

{% block title %}Modifier Rendez-vous | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">

    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}

    <div class="ac-main" data-controller="flash-toast">

        {% include 'access_control/components/_topbar.html.twig' with {
            title: 'Modifier Rendez-vous',
            subtitle: 'Mettre à jour votre consultation',
            username: userName
        } %}

        {% for message in app.flashes('success') %}
            <span data-flash-toast-target="message" data-type="success" hidden>{{ message }}</span>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <span data-flash-toast-target="message" data-type="error" hidden>{{ message }}</span>
        {% endfor %}

        <section class="ac-card edit-shell">

<style>
.edit-shell{
    max-width:820px;
    margin:auto;
    padding:1.4rem;
}

.edit-header{
    display:flex;
    align-items:center;
    gap:1rem;
    margin-bottom:1.4rem;
    padding-bottom:1rem;
    border-bottom:1px solid #eef2f7;
}

.edit-avatar{
    width:64px;
    height:64px;
    border-radius:50%;
    display:flex;
    align-items:center;
    justify-content:center;
    color:#fff;
    font-size:1.15rem;
    font-weight:800;
    background:linear-gradient(135deg,#2f6f6d,#57a7a3);
    flex-shrink:0;
}

.edit-name{
    margin:0;
    font-size:1.1rem;
    font-weight:800;
    color:#0f172a;
}

.edit-sub{
    margin-top:.2rem;
    color:#64748b;
    font-size:.9rem;
}

.info-strip{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(190px,1fr));
    gap:.8rem;
    margin-bottom:1.2rem;
}

.info-box{
    background:#f8fafc;
    border:1px solid #eef2f7;
    border-radius:16px;
    padding:.9rem;
}

.info-label{
    font-size:.75rem;
    color:#94a3b8;
    text-transform:uppercase;
    font-weight:700;
    letter-spacing:.04em;
    margin-bottom:.35rem;
}

.info-value{
    font-weight:700;
    color:#0f172a;
}

.form-grid{
    display:grid;
    gap:1rem;
}

.field-box{
    background:#fff;
    border:1px solid #eef2f7;
    border-radius:18px;
    padding:1rem;
}

.field-box label{
    display:block;
    margin-bottom:.55rem;
    font-weight:700;
    color:#0f172a;
}

.field-box input,
.field-box textarea,
.field-box select{
    width:100%;
    border:1px solid #dbe3ee;
    border-radius:14px;
    padding:.85rem .95rem;
    outline:none;
    transition:.2s;
    background:#fff;
}

.field-box input:focus,
.field-box textarea:focus,
.field-box select:focus{
    border-color:#2f6f6d;
    box-shadow:0 0 0 4px rgba(47,111,109,.08);
}

.form-error{
    margin-top:.45rem;
    color:#dc2626;
    font-size:.84rem;
}

.action-row{
    display:flex;
    gap:.8rem;
    flex-wrap:wrap;
    margin-top:1.2rem;
}

.btn-save{
    border:none;
    padding:.92rem 1.2rem;
    border-radius:14px;
    font-weight:800;
    color:#fff;
    text-decoration:none;
    background:linear-gradient(135deg,#2f6f6d,#57a7a3);
    box-shadow:0 10px 25px rgba(47,111,109,.18);
    transition:.2s;
}

.btn-save:hover{
    transform:translateY(-2px);
}

.btn-back{
    padding:.92rem 1.2rem;
    border-radius:14px;
    font-weight:700;
    text-decoration:none;
    color:#334155;
    background:#f8fafc;
    border:1px solid #e2e8f0;
}
</style>

{% set doctorName = (
    doctor.profile.firstName|default('') ~ ' ' ~ doctor.profile.lastName|default('')
)|trim %}

<div class="edit-header">

    <div class="edit-avatar">
        {{ doctor.profile.firstName|default(doctor.email)|slice(0,1)|upper }}
    </div>

    <div>
        <h3 class="edit-name">
            {{ doctorName != '' ? doctorName : doctor.email }}
        </h3>

        <div class="edit-sub">
            {{ doctor.profile.aboutMe|default('Therapist') }}
        </div>
    </div>

</div>

<div class="info-strip">

    <div class="info-box">
        <div class="info-label">Rendez-vous actuel</div>
        <div class="info-value">
            {{ rdv.dateTime ? rdv.dateTime|date('d/m/Y H:i') : 'Non défini' }}
        </div>
    </div>

    <div class="info-box">
        <div class="info-label">Statut</div>
        <div class="info-value">
            {{ rdv.status }}
        </div>
    </div>

</div>

{{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}

<div class="form-grid">

    <div class="field-box">
        {{ form_label(form.dateTime) }}
        {{ form_widget(form.dateTime) }}
        <div class="form-error">
            {{ form_errors(form.dateTime) }}
        </div>
    </div>

    <div class="field-box">
        {{ form_label(form.motif) }}
        {{ form_widget(form.motif) }}
        <div class="form-error">
            {{ form_errors(form.motif) }}
        </div>
    </div>

    <div class="field-box">
        {{ form_label(form.description) }}
        {{ form_widget(form.description, {'attr': {'rows': 5}}) }}
        <div class="form-error">
            {{ form_errors(form.description) }}
        </div>
    </div>

</div>

<div class="action-row">

    <button class="btn-save">
        <i class="bi bi-check-circle"></i>
        Enregistrer les modifications
    </button>

    <a href="{{ path('app_patient_rdv') }}" class="btn-back">
        Retour
    </a>

</div>

{{ form_end(form) }}

        </section>

    </div>
</div>
{% endblock %}