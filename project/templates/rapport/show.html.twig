{% extends 'access_control/layout.html.twig' %}

{% block title %}Rapport Patient | Serinity{% endblock %}

{% block content %}
<div class="ac-app-layout">

    {% include 'access_control/components/_sidebar.html.twig' with { items: nav } %}

    <div class="ac-main" data-controller="flash-toast">

        {% include 'access_control/components/_topbar.html.twig' with {
            title: 'Rapport Médical',
            subtitle: 'Suivi patient et historique des consultations',
            username: userName
        } %}

        {% for message in app.flashes('success') %}
            <span data-flash-toast-target="message" data-type="success" hidden>{{ message }}</span>
        {% endfor %}

        {% for message in app.flashes('error') %}
            <span data-flash-toast-target="message" data-type="error" hidden>{{ message }}</span>
        {% endfor %}

<section class="ac-card report-shell">

<style>
.report-shell{
    padding:1.4rem;
}

.report-header{
    background:#fff;
    border:1px solid #eef2f7;
    border-radius:22px;
    padding:1.2rem;
    display:flex;
    align-items:center;
    gap:1rem;
    margin-bottom:1.2rem;
    box-shadow:0 10px 25px rgba(15,23,42,.04);
}

.avatar-lg{
    width:68px;
    height:68px;
    border-radius:50%;
    background:linear-gradient(135deg,#2F6F6D,#57a7a3);
    color:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:1.25rem;
    font-weight:800;
    flex-shrink:0;
}

.patient-name{
    margin:0;
    font-size:1.15rem;
    font-weight:800;
    color:#0f172a;
}

.patient-sub{
    margin-top:.2rem;
    color:#64748b;
    font-size:.9rem;
}

.info-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
    gap:.8rem;
    margin-bottom:1.2rem;
}

.info-card{
    background:#f8fafc;
    border:1px solid #eef2f7;
    border-radius:18px;
    padding:1rem;
}

.info-label{
    font-size:.75rem;
    color:#94a3b8;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:.35rem;
}

.info-value{
    font-weight:700;
    color:#0f172a;
}

.panel-box{
    background:#fff;
    border:1px solid #eef2f7;
    border-radius:22px;
    padding:1.1rem;
    box-shadow:0 10px 25px rgba(15,23,42,.04);
}

.panel-head{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:1rem;
    margin-bottom:1rem;
    flex-wrap:wrap;
}

.section-title{
    margin:0;
    font-size:1rem;
    font-weight:800;
    color:#0f172a;
}

.btn-add{
    text-decoration:none;
    padding:.75rem 1rem;
    border-radius:14px;
    font-size:.85rem;
    font-weight:800;
    color:#fff;
    background:linear-gradient(135deg,#16a34a,#22c55e);
    box-shadow:0 10px 20px rgba(34,197,94,.18);
}

.consultation-list{
    display:flex;
    flex-direction:column;
    gap:1rem;
}

.consultation-card{
    background:#f8fafc;
    border:1px solid #eef2f7;
    border-left:5px solid #2F6F6D;
    border-radius:18px;
    padding:1rem;
    transition:.2s;
}

.consultation-card:hover{
    transform:translateY(-2px);
}

.row-top{
    display:flex;
    justify-content:space-between;
    gap:1rem;
    flex-wrap:wrap;
    margin-bottom:.8rem;
}

.date-line{
    color:#64748b;
    font-size:.88rem;
    font-weight:600;
}

.badge-ok{
    background:#ecfdf5;
    color:#16a34a;
    padding:.45rem .8rem;
    border-radius:999px;
    font-size:.72rem;
    font-weight:800;
}

.field{
    margin-bottom:.8rem;
}

.field-title{
    font-size:.78rem;
    color:#94a3b8;
    text-transform:uppercase;
    font-weight:700;
    margin-bottom:.25rem;
}

.field-content{
    color:#0f172a;
    font-weight:600;
    line-height:1.55;
}

.action-row{
    display:flex;
    gap:.6rem;
    flex-wrap:wrap;
    margin-top:.8rem;
}

.btn-smx{
    text-decoration:none;
    padding:.65rem .9rem;
    border-radius:12px;
    font-size:.8rem;
    font-weight:800;
}

.btn-edit{
    background:#eff6ff;
    color:#2563eb;
}

.btn-delete{
    background:#fef2f2;
    color:#dc2626;
}

.empty-box{
    text-align:center;
    padding:2rem 1rem;
    color:#94a3b8;
}
</style>

{% set patientName = (patient.firstName ~ ' ' ~ patient.lastName)|trim %}
{% set displayName = patientName != '' ? patientName : patient.email %}

<div class="report-header">

    <div class="avatar-lg">
        {{ displayName|slice(0,1)|upper }}
    </div>

    <div>
        <h3 class="patient-name">{{ displayName }}</h3>
        <div class="patient-sub">
            Rapport médical du patient
        </div>

    </div>
        <a href="{{ path('app_rapport_pdf', {id: patient.id}) }}" class="btn-add">
    <i class="bi bi-file-earmark-pdf"></i>
    Télécharger PDF
</a>
</div>

<div class="info-grid">

    <div class="info-card">
        <div class="info-label">Email</div>
        <div class="info-value">{{ patient.email }}</div>
    </div>

    <div class="info-card">
        <div class="info-label">Téléphone</div>
        <div class="info-value">{{ patient.phone ?: 'Non renseigné' }}</div>
    </div>

    <div class="info-card">
        <div class="info-label">Pays</div>
        <div class="info-value">{{ patient.country ?: 'Non renseigné' }}</div>
    </div>

    <div class="info-card">
        <div class="info-label">Région</div>
        <div class="info-value">{{ patient.state ?: 'Non renseigné' }}</div>
    </div>

</div>

<div class="panel-box">

    <div class="panel-head">

        <h4 class="section-title">
            <i class="bi bi-clipboard2-pulse"></i>
            Consultations
        </h4>

        <a href="{{ path('app_consultation_new', {id: rapport.id}) }}" class="btn-add">
            <i class="bi bi-plus-circle"></i>
            Ajouter Consultation
        </a>
{# ===== ADD INSIDE .panel-head AFTER Ajouter Consultation BUTTON ===== #}

<div style="display:flex; gap:.6rem; flex-wrap:wrap; align-items:center;">

    <select id="translateLang" class="btn-smx"
            style="border:1px solid #e5e7eb;background:#fff;">
        <option value="en">English</option>
        <option value="ar">العربية</option>
        <option value="it">Italiano</option>
        <option value="es">Español</option>
        <option value="de">Deutsch</option>
        <option value="tr">Türkçe</option>
    </select>

    <button type="button"
            class="btn-add"
            onclick="translateConsultations()">
        <i class="bi bi-translate"></i>
        Traduire
    </button>

    <button type="button"
            class="btn-smx btn-edit"
            onclick="restoreOriginal()">
        <i class="bi bi-arrow-counterclockwise"></i>
        Original
    </button>

</div>
    </div>

    <div class="consultation-list">

        {% for c in consultations %}

            <div class="consultation-card">

                <div class="row-top">

                    <div class="date-line">
                        <i class="bi bi-calendar-event"></i>
                        {{ c.dateConsultation|date('d/m/Y H:i') }}
                    </div>

                    <span class="badge-ok">
                        Consultation
                    </span>

                </div>

                <div class="field">
                    <div class="field-title">Diagnostic</div>
                   <div class="field-content translatable"
     data-original="{{ c.diagnostic ?: 'Non renseigné' }}">
    {{ c.diagnostic ?: 'Non renseigné' }}
</div>
                </div>

                <div class="field">
                    <div class="field-title">Prescription</div>
                <div class="field-content translatable"
     data-original="{{ c.prescription ?: 'Non renseigné' }}">
    {{ c.prescription ?: 'Non renseigné' }}
</div>
                </div>

                <div class="field">
                    <div class="field-title">Notes</div>
                <div class="field-content translatable"
     data-original="{{ c.notes ?: 'Aucune note' }}">
    {{ c.notes ?: 'Aucune note' }}
</div>
                </div>

                <div class="action-row">

                    <a href="{{ path('app_consultation_edit', {id: c.id}) }}" class="btn-smx btn-edit">
                        <i class="bi bi-pencil-square"></i>
                        Modifier
                    </a>

                    <a href="{{ path('app_consultation_delete', {id: c.id}) }}"
                       class="btn-smx btn-delete"
                       onclick="return confirm('Supprimer cette consultation ?');">
                        <i class="bi bi-trash"></i>
                        Supprimer
                    </a>

                </div>

            </div>

        {% else %}

            <div class="empty-box">
                <i class="bi bi-clipboard-x" style="font-size:2rem;"></i>
                <div style="margin-top:.7rem;">
                    Aucune consultation disponible
                </div>
            </div>

        {% endfor %}

    </div>

</div>

</section>

    </div>
</div>


{# ===== ADD BEFORE {% endblock %} ===== #}

<script>
document.addEventListener('DOMContentLoaded', function () {
    window.translateConsultations = function () {
        const lang = document.getElementById('translateLang').value;
        const items = document.querySelectorAll('.translatable');

        items.forEach((el) => {
            const text = el.getAttribute('data-original') || el.textContent;

            fetch('{{ path('app_consultation_translate') }}', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded'
                },
                body: 'text=' + encodeURIComponent(text) + '&lang=' + encodeURIComponent(lang)
            })
            .then(r => r.json())
            .then(data => {
                if (data.success) {
                    el.textContent = data.translated;
                }
            });
        });
    };

    window.restoreOriginal = function () {
        document.querySelectorAll('.translatable').forEach((el) => {
            el.textContent = el.getAttribute('data-original') || '';
        });
    };
});
</script>

{% endblock %}
