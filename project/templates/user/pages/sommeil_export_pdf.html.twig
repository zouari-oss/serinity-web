<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Sommeils export</title>
    <style>
        body { font-family: Arial, sans-serif; font-size: 12px; color: #111; }
        h1 { font-size: 18px; margin-bottom: 12px; }
        table { width: 100%; border-collapse: collapse; }
        th, td { border: 1px solid #ddd; padding: 6px; text-align: left; }
        th { background: #f3f3f3; }
    </style>
</head>
<body>
<h1>Sommeils</h1>
<table>
    <thead>
    <tr>
        <th>Date</th>
        <th>Coucher</th>
        <th>Réveil</th>
        <th>Durée</th>
        <th>Qualité</th>
        <th>Humeur</th>
        <th>Interruptions</th>
        <th>Statut</th>
    </tr>
    </thead>
    <tbody>
    {% for row in rows %}
        <tr>
            <td>{{ row.sleepDate ?? '' }}</td>
            <td>{{ row.bedTime ?? '' }}</td>
            <td>{{ row.wakeTime ?? '' }}</td>
            <td>{{ row.sleepDuration ?? '' }}</td>
            <td>{{ row.quality ?? '' }}</td>
            <td>{{ row.humeur_reveil ?? '' }}</td>
            <td>{{ row.interruptions ?? '' }}</td>
            <td>{{ row.insufficient ? 'Sommeil insuffisant' : 'Normal' }}</td>
        </tr>
    {% endfor %}
    </tbody>
</table>
</body>
</html>
