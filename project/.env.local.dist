### Local development environment template
APP_ENV=dev
APP_DEBUG=1
APP_SECRET=change_me_local_secret
DEFAULT_URI=http://127.0.0.1:8000

### Local database (Docker Postgres from compose.yaml)
DATABASE_URL="postgresql://app:!ChangeMe!@127.0.0.1:5432/app?serverVersion=16&charset=utf8"

### Optional local overrides for external integrations
MAILER_DSN=null://null
