{% extends 'access_control/layout.html.twig' %}
{% block title %}Reset password | Serinity{% endblock %}

{% set pageStep = step|default('request') %}

{% block content %}
<main
    class="ac-center-page"
    data-controller="password-reset"
    data-password-reset-step-value="{{ pageStep }}"
    data-password-reset-forgot-url-value="{{ path('api_auth_forgot_password') }}"
    data-password-reset-verify-url-value="{{ path('api_auth_verify_reset_code') }}"
    data-password-reset-reset-url-value="{{ path('api_auth_reset_password') }}"
    data-password-reset-page-url-value="{{ path('ac_ui_reset_password') }}"
    data-password-reset-expires-in-value="900"
>
    <p class="ac-inline-error ac-reset-status" data-password-reset-target="status" hidden></p>

    {% if pageStep == 'request' %}
        <section class="ac-card ac-reset-screen">
            <h2>Forgot password?</h2>
            <p class="ac-reset-subtitle">Enter your email address to receive a 6-digit reset code.</p>

            <form class="ac-form" data-password-reset-target="requestForm" data-action="submit->password-reset#requestCodeAction">
                <label>
                    <span class="ac-label">Email</span>
                    <input class="ac-input" type="email" placeholder="Enter your email" data-password-reset-target="requestEmail" required>
                </label>
                <button class="ac-btn ac-btn-primary" type="submit">Send code</button>
            </form>
        </section>
    {% elseif pageStep == 'verify' %}
        <section class="ac-card ac-reset-screen">
            <h2>Reset password</h2>
            <p class="ac-reset-subtitle" data-password-reset-target="verifyHint">Enter the 6-digit code sent to your email.</p>

            <form class="ac-form" data-password-reset-target="verifyForm" data-action="submit->password-reset#verifyCodeAction">
                <label>
                    <span class="ac-label">Verification code</span>
                    <div class="ac-otp-grid">
                        {% for i in 0..5 %}
                            <input
                                class="ac-input ac-otp-input"
                                type="text"
                                inputmode="numeric"
                                pattern="[0-9]"
                                maxlength="1"
                                data-password-reset-target="otpInput"
                                data-action="input->password-reset#onOtpInput keydown->password-reset#onOtpKeydown paste->password-reset#onOtpPaste"
                                required
                            >
                        {% endfor %}
                    </div>
                </label>
                <button class="ac-btn ac-btn-primary" type="submit">Verify code</button>
            </form>

            <p class="ac-reset-countdown" data-password-reset-target="countdown"></p>
            <button class="ac-link-btn" type="button" data-password-reset-target="resendButton" data-action="click->password-reset#resendCodeAction">Resend code</button>
        </section>
    {% else %}
        <section class="ac-card ac-reset-screen">
            <h2>Create new password</h2>
            <p class="ac-reset-subtitle">Choose a strong password for your account.</p>

            <form class="ac-form ac-reset-password-box" data-password-reset-target="passwordForm" data-action="submit->password-reset#resetPasswordAction">
                <label>
                    <span class="ac-label">New password</span>
                    <input class="ac-input" type="password" minlength="8" autocomplete="new-password" data-password-reset-target="resetPassword" required>
                </label>
                <p class="ac-reset-note">At least 8 characters with uppercase, lowercase, a number, and a symbol.</p>
                <button class="ac-btn ac-btn-primary" type="submit">Reset password</button>
            </form>
        </section>
    {% endif %}

    <a class="ac-link-btn" href="{{ path('ac_ui_login') }}">Back to login</a>
</main>
{% endblock %}
