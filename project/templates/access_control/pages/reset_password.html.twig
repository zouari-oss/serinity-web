{% extends 'access_control/layout.html.twig' %}
{% block title %}Reset password | Serinity{% endblock %}

{% block content %}
<main class="ac-center-page" data-controller="form-feedback">
    <section class="ac-card">
        <h2>Reset password</h2>
        <p>Request a reset code, then confirm your new password.</p>
        <div class="ac-grid-two">
            <form class="ac-form" data-action="submit->form-feedback#validate" method="post" action="{{ path('api_auth_reset_send') }}">
                <label>Email<input class="ac-input" type="email" name="email" required></label>
                <button class="ac-btn" type="submit">Send code</button>
            </form>
            <form class="ac-form" data-action="submit->form-feedback#validate" method="post" action="{{ path('api_auth_reset_confirm') }}">
                <label>Email<input class="ac-input" type="email" name="email" required></label>
                <label>Code<input class="ac-input" type="text" name="code" required></label>
                <label>New password<input class="ac-input" type="password" name="newPassword" minlength="8" required></label>
                <button class="ac-btn" type="submit">Confirm reset</button>
            </form>
        </div>
        <a class="ac-link-btn" href="{{ path('ac_ui_login') }}">Back to login</a>
    </section>
</main>
{% endblock %}
