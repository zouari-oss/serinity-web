<aside class="ac-sidebar">
    <div class="ac-brand">
        <div class="ac-brand-badge">S</div>
        <div>
            <p class="ac-brand-name">Serinity</p>
            <p class="ac-brand-sub">Access Control</p>
        </div>
    </div>

    <nav class="ac-nav" aria-label="Primary">
        {% set currentSection = null %}
        {% for item in items %}
            {% if currentSection != item.section %}
                {% if currentSection is not null %}
                    <div class="ac-nav-divider" aria-hidden="true"></div>
                {% endif %}
                {% set currentSection = item.section %}
            {% endif %}
            <a class="ac-nav-link {{ item.active ? 'is-active' : '' }}" href="{{ path(item.route) }}">
                <span class="material-symbols-outlined">{{ item.icon|default('chevron_right') }}</span>
                <span>{{ item.label }}</span>
            </a>
        {% endfor %}
    </nav>
</aside>
