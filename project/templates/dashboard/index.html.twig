<script>
document.addEventListener('DOMContentLoaded', () => {

    function setupTable({
        rowsSelector,
        searchInput,
        statusFilter = null,
        aiFilter = null,
        pagesContainer,
        countContainer,
        perPage = 6
    }) {
        const rows = [...document.querySelectorAll(rowsSelector)];
        const search = document.querySelector(searchInput);
        const status = statusFilter ? document.querySelector(statusFilter) : null;
        const ai = aiFilter ? document.querySelector(aiFilter) : null;
        const pages = document.querySelector(pagesContainer);
        const count = document.querySelector(countContainer);

        let currentPage = 1;

        function render() {
            const term = search ? search.value.toLowerCase().trim() : '';
            const statusVal = status ? status.value : '';
            const aiVal = ai ? ai.value : '';

            const filtered = rows.filter(row => {
                const txt = row.dataset.search || '';
                const rowStatus = row.dataset.status || '';
                const rowAi = row.dataset.ai || '';

                const matchSearch = txt.includes(term);
                const matchStatus = !statusVal || rowStatus === statusVal;
                const matchAi = !aiVal || rowAi === aiVal;

                return matchSearch && matchStatus && matchAi;
            });

            const totalPages = Math.max(1, Math.ceil(filtered.length / perPage));
            if (currentPage > totalPages) currentPage = 1;

            rows.forEach(r => r.style.display = 'none');

            const start = (currentPage - 1) * perPage;
            const end = start + perPage;

            filtered.slice(start, end).forEach(row => {
                row.style.display = '';
            });

            count.innerHTML = filtered.length + ' résultat(s)';

            pages.innerHTML = '';

            for (let i = 1; i <= totalPages; i++) {
                const btn = document.createElement('button');
                btn.className = 'page-btn' + (i === currentPage ? ' active' : '');
                btn.innerText = i;

                btn.addEventListener('click', () => {
                    currentPage = i;
                    render();
                });

                pages.appendChild(btn);
            }

            if (filtered.length === 0) {
                count.innerHTML = 'Aucun résultat';
            }
        }

        [search, status, ai].forEach(el => {
            if (el) {
                el.addEventListener('input', () => {
                    currentPage = 1;
                    render();
                });

                el.addEventListener('change', () => {
                    currentPage = 1;
                    render();
                });
            }
        });

        render();
    }

    setupTable({
        rowsSelector: '.rdv-row',
        searchInput: '#rdvSearch',
        statusFilter: '#rdvStatusFilter',
        aiFilter: '#rdvAiFilter',
        pagesContainer: '#rdvPages',
        countContainer: '#rdvCount',
        perPage: 6
    });

    setupTable({
