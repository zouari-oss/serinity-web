{% extends 'forum/embedded_layout.html.twig' %}
{% set topbarTitle = mode == 'create' ? 'New thread' : 'Edit thread' %}
{% set topbarSubtitle = mode == 'create' ? 'Start a discussion' : 'Update your post' %}
{% set showForumNav = false %}

{% block title %}{{ mode == 'create' ? 'New Thread' : 'Edit Thread' }}{% endblock %}

{% block forum_content %}
<main class="page-shell">
    <div class="container" style="max-width: 1100px;">
        <section class="hero-shell p-4 p-md-5 mb-3">
            <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
                <div>
                    <p class="text-uppercase fw-bold mb-1 small text-primary section-kicker">Forum Studio</p>
                    <h1 class="h4 mb-2">{{ mode == 'create' ? 'Create a new thread' : 'Edit your thread' }}</h1>
                    <p class="text-muted mb-0">Ask a question, share an update, or start a discussion.</p>
                </div>
                <a class="btn btn-outline-primary" href="{{ path('app_forum_feed') }}">Back to feed</a>
            </div>
        </section>

        <div class="row g-3">
            <div class="col-lg-8">
                <section class="card-soft p-4">
                    {% set dangerMessages = app.flashes('danger') %}
                    {% set warningMessages = app.flashes('warning') %}
                    {% set threadErrorMessage = threadError|default(null) %}
                    {% if threadErrorMessage %}
                        <div class="thread-error-line" role="alert">{{ threadErrorMessage }}</div>
                    {% endif %}
                    {% for message in dangerMessages %}
                        <div class="thread-error-line" role="alert">{{ message }}</div>
                    {% endfor %}
                    {% for message in warningMessages %}
                        <div class="thread-error-line" role="alert">{{ message }}</div>
                    {% endfor %}
                    {{ form_start(form, {'attr': {'novalidate': 'novalidate'}}) }}
                        <div class="mb-3">
                            {{ form_row(form.title, { attr: { class: 'form-control forum-input' } }) }}
                        </div>
                        <div class="mb-3">
                            {{ form_row(form.content, { attr: { class: 'form-control forum-textarea' } }) }}
                        </div>
                        <div class="row g-3">
                            <div class="col-md-6">
                                {{ form_row(form.category, { attr: { class: 'form-select forum-select' } }) }}
                            </div>
                            <div class="col-md-6">
                                {{ form_row(form.type, { attr: { class: 'form-select forum-select' } }) }}
                            </div>
                        </div>
                        <div class="row g-3 mt-1">
                            <div class="col-md-6">
                                {{ form_row(form.imageFile, { attr: { class: 'form-control forum-file' } }) }}
                            </div>
                            <div class="col-md-6 d-flex align-items-center">
                                {{ form_row(form.isPinned, { attr: { class: 'form-check-input' } }) }}
                            </div>
                        </div>
                        {% if mode == 'create' %}
                            <input type="hidden" name="force_publish" id="forcePublishInput" value="0">
                        {% endif %}
                        <div class="d-flex flex-wrap gap-2 mt-3">
                            <button class="btn btn-primary">{{ mode == 'create' ? 'Publish' : 'Update' }}</button>
                            <a class="btn btn-outline-primary" href="{{ path('app_forum_feed') }}">Cancel</a>
                        </div>
                    {{ form_end(form) }}
                </section>
            </div>
            <div class="col-lg-4">
                <section class="card-soft p-4">
                    <h2 class="h6 text-uppercase section-kicker mb-2">Posting tips</h2>
                    <ul class="text-muted small mb-0">
                        <li>Use a clear, specific title for faster replies.</li>
                        <li>Share context, what you tried, and what you need.</li>
                        <li>Choose the most relevant category and type.</li>
                        <li>Add an image if it helps explain the issue.</li>
                    </ul>
                </section>
                <section class="card-soft p-4 mt-3">
                    <h2 class="h6 text-uppercase section-kicker mb-2">Duplicate radar</h2>
                    <p class="small text-muted mb-0">Before publishing, we check for similar threads to keep discussions organized.</p>
                </section>
            </div>
        </div>

        {% if mode == 'create' %}
            <div class="modal fade" id="duplicateRadarModal" tabindex="-1" aria-labelledby="duplicateRadarTitle" aria-hidden="true">
                <div class="modal-dialog modal-lg modal-dialog-scrollable">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h2 class="modal-title h5 mb-0" id="duplicateRadarTitle">Semantic Duplicate Radar</h2>
                        </div>
                        <div class="modal-body">
                            <p class="text-muted mb-3">We found near-duplicate threads. You can continue posting, merge into an existing thread, or revive an older one.</p>
                            <div id="duplicateRadarList" class="d-flex flex-column gap-3"></div>
                        </div>
                        <div class="modal-footer d-flex justify-content-between">
                            <button type="button" class="btn btn-outline-primary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-primary" id="continuePublishBtn">Continue and Publish Anyway</button>
                        </div>
                    </div>
                </div>
            </div>
        {% endif %}
    </div>
</main>
{% endblock %}

{% block javascripts %}
    {{ parent() }}
    {% if mode == 'create' %}
        <script>
            (function () {
                const initDuplicateRadar = function () {
                    const form = document.querySelector('form[name="forum_thread"]');
                    const forcePublishInput = document.getElementById('forcePublishInput');
                    const modalEl = document.getElementById('duplicateRadarModal');
                    const listEl = document.getElementById('duplicateRadarList');
                    const continueBtn = document.getElementById('continuePublishBtn');

                    if (!form || !forcePublishInput || !modalEl || !listEl || !continueBtn) {
                        return;
                    }

                    const titleInput = form.querySelector('input[name$="[title]"]');
                    const contentInput = form.querySelector('textarea[name$="[content]"]');
                    if (!titleInput || !contentInput) {
                        return;
                    }

                    const bootstrapModal = new bootstrap.Modal(modalEl);

                    const buildRow = function (dup) {
                        const row = document.createElement('div');
                        row.className = 'card-soft p-3';
                        row.innerHTML = `
                            <div class="d-flex justify-content-between align-items-start gap-2">
                                <div>
                                    <h3 class="h6 mb-1">${dup.title}</h3>
                                    <p class="small text-muted mb-2">Score: ${dup.score} • Replies: ${dup.replyCount} • Followers: ${dup.followCount}</p>
                                </div>
                                <div class="d-flex flex-column gap-2">
                                    <form method="post" action="${dup.mergeUrl}">
                                        <input type="hidden" name="_token" value="${dup.csrf}">
                                        <input type="hidden" name="draft_content" value="${dup.draft}">
                                        <button type="submit" class="btn btn-sm btn-outline-primary">Merge</button>
                                    </form>
                                    <form method="post" action="${dup.reviveUrl}">
                                        <input type="hidden" name="_token" value="${dup.csrf}">
                                        <input type="hidden" name="draft_content" value="${dup.draft}">
                                        <button type="submit" class="btn btn-sm btn-outline-secondary">Revive</button>
                                    </form>
                                </div>
                            </div>
                            <p class="mb-0">${dup.preview}</p>
                        `;

                        return row;
                    };

                    form.addEventListener('submit', function (event) {
                        if (forcePublishInput.value === '1') {
                            return;
                        }

                        event.preventDefault();

                        const data = new FormData();
                        data.append('_token', form.querySelector('input[name="_token"]').value);
                        data.append('title', titleInput.value || '');
                        data.append('content', contentInput.value || '');

                        fetch("{{ path('app_thread_duplicate_radar') }}", {
                            method: 'POST',
                            body: data,
                        }).then(response => response.json()).then(payload => {
                            if (!payload.ok || !payload.duplicates || payload.duplicates.length === 0) {
                                forcePublishInput.value = '1';
                                form.requestSubmit();
                                return;
                            }

                            listEl.innerHTML = '';
                            payload.duplicates.forEach(dup => {
                                listEl.appendChild(buildRow(dup));
                            });

                            bootstrapModal.show();
                        }).catch(() => {
                            forcePublishInput.value = '1';
                            form.requestSubmit();
                        });
                    });

                    continueBtn.addEventListener('click', function () {
                        forcePublishInput.value = '1';
                        bootstrapModal.hide();
                        form.requestSubmit();
                    });
                };

                if (document.readyState === 'loading') {
                    document.addEventListener('DOMContentLoaded', initDuplicateRadar);
                } else {
                    initDuplicateRadar();
                }
            })();
        </script>
    {% endif %}
{% endblock %}
